# Runtime
NODE_ENV=development
PORT=4000
TRUST_PROXY=false

# Security / Auth
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_VALUE
JWT_ISSUER=brightfoundry
JWT_AUDIENCE=brightfoundry-portal
JWT_EXPIRES_IN=1h

# Database
DATABASE_URL=file:./prisma/dev.db

# CORS (dev example)
ALLOWED_ORIGINS=http://127.0.0.1:5055,http://localhost:5055,http://127.0.0.1:5500,http://localhost:5500

# Prisma seed (keep off by default)
SEED_ALLOW=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
