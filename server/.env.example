NODE_ENV=development
PORT=4000
DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="change-me-to-a-strong-random-secret"

# Comma-separated list of allowed web origins (exact match) for CORS in production.
# Example: https://brightfoundry.co.uk,https://www.brightfoundry.co.uk
CORS_ORIGINS="http://localhost:3000"

# If you run the API behind a reverse proxy/load balancer in staging/prod, enable this.
TRUST_PROXY="false"

# Allow public self-service registration (invite-only if false).
ALLOW_PUBLIC_REGISTER="false"
