# ─────────────────────────────────────────────────────────────────────
# BrightFoundry Prospecting Tool — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────

# Google Places API key (required for the scraper)
# Create one at: https://console.cloud.google.com/
# Enable: Places API (new) or Places API (legacy)
GOOGLE_PLACES_API_KEY=

# ── Volume controls (keep low in v1) ─────────────────────────────────

# Maximum prospects to scrape per full run (across all queries+cities)
# Default: 30.  Never set above 100 in v1.
SCRAPE_RUN_CAP=30

# Maximum Places API results to request per query (max 20 per page)
SCRAPE_PAGE_SIZE=20

# Delay in milliseconds between Places API calls (be polite)
SCRAPE_DELAY_MS=1000

# Minimum score (0-100) a prospect must reach to be kept after scraping
SCRAPE_SCORE_THRESHOLD=40

# ── SQLite database path ──────────────────────────────────────────────
# Default: ./data/prospects.db  (created automatically on first run)
DB_PATH=./data/prospects.db

# ── Exports ──────────────────────────────────────────────────────────
# Where CSV review files are written
EXPORT_DIR=./exports

# Website audit controls
# One lightweight page request per prospect. Keep delays/timeouts conservative.
WEBSITE_AUDIT_TIMEOUT_MS=8000
WEBSITE_AUDIT_DELAY_MS=1000

# Outreach sending safety switches
# Live email sending is OFF unless AUTO_SEND is explicitly set to true.
AUTO_SEND=false

# Live sending is blocked unless this stays true.
# When true, send-daily only sends queue rows whose prospect is marked approved.
REQUIRE_MANUAL_APPROVAL=true

# Hard-capped in code at 10 even if this value is set higher.
DAILY_SEND_LIMIT=10

# Optional Resend configuration for live sending.
# Leave blank for dry-run only.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
